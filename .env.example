# Public hostname for TLS, DoH, and Pi-hole web (FQDN, e.g. example.com)
SERVER_HOSTNAME=your-hostname.com

# Pi-hole host LAN IPv4 (used in dnsmasq shared-network / DHCP DNS option)
PIHOLE_LAN_IP=192.168.x.x

# Optional — omit entirely if you do not use Hostinger. API token for
# extra-script/update-dns-record-hostinger.sh and extra-script/certbot-hook-dns.sh
# (passed to nginx when set). Leave unset to skip Hostinger automation.
# DNS_API=

# DoH proxy (doh service) — upstream is Pi-hole on the compose network by default
# DOH_UPSTREAM_DNS=172.28.0.3:53
# URL path segment for DoH (nginx and doh-server must agree)
# DOH_PATH_PREFIX=consulta-dns
# Public HTTPS port advertised for DoH (-j flag); nginx maps host 440 -> doh
# DOH_PUBLIC_PORT=440

# WireGuard egress and DNS allowlist (defaults match docker-compose internal IPs)
# LOCAL_DNS_IP=172.28.0.3
# LOCAL_ALLOWLIST=172.28.0.2,172.28.0.3,172.28.0.4,172.28.0.5
# Host interface name for outbound traffic from the WireGuard container
# WG_EGRESS_IFACE=eth0

# Docker bridge MTU (optional)
# NETWORK_MTU=1500

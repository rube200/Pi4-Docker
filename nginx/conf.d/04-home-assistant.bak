server {
    access_log /var/log/nginx/access_home-assistant.log;
    error_log /var/log/nginx/error_home-assistant.log;

    include /etc/nginx/common.d/common.conf;

    server_name home-assistant.$SERVER_HOSTNAME;

    location / {
        proxy_pass http://127.0.0.1:8123;
        include /etc/nginx/common.d/proxy_params.conf;
    }
}